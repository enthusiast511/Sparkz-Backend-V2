OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-4o
REVIEW_MODEL=gpt-4o-mini

# Optional: lower value (e.g. 6) reduces tokens-per-minute spikes and 429 rate limits.
# BATCH_SIZE=12

# Production frontend URLs (comma-separated, no spaces). Required for Vercel → Render.
# CORS_ALLOWED_ORIGINS=https://spark-frontend-v2.vercel.app
